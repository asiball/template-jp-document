' =============================================================================
' template/plantuml.config — 全 PlantUML 図に共通適用する設定
' (Makefile が plantuml の -config として全図の変換に自動適用する)
'
' 図中テキストのフォント・配色などの共通デザインを PDF 本文の紙面テーマ
' (template/spec.typ)に揃える。フォントについては Typst が SVG 内の
' <text> をイメージ内の /opt/fonts(--font-path)から解決するため、ここで
' 指定するファミリー名は Typst が解決できる名前でなければならない
' (BUILDING.md の「フォント」節参照)。
'
' 図の見た目に関する共通設定を追加したい場合もこのファイルに書く(美観の
' 定義を template/ に集約する方針。個々の図固有の設定は各 .puml に書いてよい)。
' =============================================================================
skinparam defaultFontName "Source Han Sans JP"

' ---- 共通(spec.typ の色定数と揃える) --------------------------------------
skinparam shadowing false
skinparam roundCorner 6
' 矢印と矢印ラベル: body-text-gray
skinparam ArrowColor #4D4D4D
skinparam ArrowFontColor #4D4D4D
' タイトル: accent-color
skinparam TitleFontColor #1F4E79
' ノート: 本文の引用ブロック(コード背景相当の淡色+罫線グレー)に合わせる
skinparam NoteBackgroundColor #FAFAFA
skinparam NoteBorderColor #C9C9C9

' ---- シーケンス図(table-header-bg + accent-color の「薄グレー地+濃紺枠」) --
skinparam SequenceParticipantBackgroundColor #EEF1F5
skinparam SequenceParticipantBorderColor #1F4E79
skinparam SequenceActorBackgroundColor #FFFFFF
skinparam SequenceActorBorderColor #1F4E79
' ライフライン: rule-gray、活性化バー: table-header-bg
skinparam SequenceLifeLineBorderColor #C9C9C9
skinparam LifeLineBackgroundColor #EEF1F5
' alt/loop 等のグループ枠: ヘッダ帯 table-header-bg + 枠 accent-soft
skinparam SequenceGroupBackgroundColor #EEF1F5
skinparam SequenceGroupBorderColor #4A6D8C
skinparam SequenceDividerBackgroundColor #EEF1F5
skinparam SequenceDividerBorderColor #C9C9C9

' ---- 状態遷移図 -------------------------------------------------------------
skinparam StateBackgroundColor #EEF1F5
skinparam StateBorderColor #1F4E79
skinparam StateStartColor #1F4E79
skinparam StateEndColor #1F4E79

' ---- クラス図(将来用の最小限) ----------------------------------------------
skinparam ClassBackgroundColor #FFFFFF
skinparam ClassBorderColor #1F4E79
skinparam ClassHeaderBackgroundColor #EEF1F5
